    "python3 -m amos.evaluation.product_eval --scenario warehouse_quality --variants 12 --samples 3 --variant-seed 20260711 --systems amos,agent_with_manual_policy_prompt,rag_with_permission_filter,agent_only,rag,semantic,catalog,long_context,amos_no_verifier,amos_no_permission_gate,amos_no_provenance"
  ],
